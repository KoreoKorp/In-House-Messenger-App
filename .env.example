# ============================================================
# JEAN'S MESSENGER — Environment Variables
# ============================================================
# 1. Copy this file and rename it to ".env"
# 2. Fill in your values below
# 3. NEVER share your .env file or upload it to GitHub
# ============================================================

# The PIN Jean uses to log into her chat page (4 digits recommended)
JEAN_PIN=1234

# The password YOU use to access the admin page
ADMIN_PASSWORD=choose_a_strong_password_here

# The port the server runs on (3000 is fine, or use 80 for web standard)
PORT=3000
